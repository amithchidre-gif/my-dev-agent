# Dev environment — safe to commit (no real secrets)
# Copy to .env.dev.local and override for personal settings.

NODE_ENV=development

# Agent server
PORT=3000

# QA agent server
QA_PORT=3003

# Auth — leave empty to disable in dev
QA_API_KEY=

# Evidence storage root
QA_EVIDENCE_DIR=./evidence

# Branch this environment tracks
GIT_ENV_BRANCH=dev
