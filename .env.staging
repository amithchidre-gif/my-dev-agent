# Staging environment — safe to commit (no real secrets)
# Real secrets (QA_API_KEY etc.) go in CI/CD environment variables, NOT here.

NODE_ENV=staging

# Agent server
PORT=3000

# QA agent server
QA_PORT=3003

# Auth — set via CI secret QA_API_KEY; placeholder shown here
QA_API_KEY=REPLACE_WITH_CI_SECRET

# Evidence storage root
QA_EVIDENCE_DIR=./evidence

# Branch / ref this environment tests against
GIT_ENV_BRANCH=main
